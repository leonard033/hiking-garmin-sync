# 复制为 .env 并填入真实值（不要提交 .env）

# 方式 A（推荐）：用本地生成的 OAuth token 登录（稳定，不易被风控）
# 运行 python generate_token.py 生成后，把 base64 字符串贴到下面
GARMIN_TOKEN=

# 方式 B：账号密码直连（中国区 garmin.cn）
# 如果 Railway 云服务器被 Garmin 风控，可能登录失败，建议改用方式 A
GARMIN_USER=你的佳明邮箱
GARMIN_PASS=你的佳明密码
GARMIN_IS_CN=true

# 手机端访问后端用的令牌（请改成一段随机长字符串）
SYNC_TOKEN=请换成随机长字符串例如-a1b2c3d4e5f6

# 拉取设置
PULL_INTERVAL_MIN=30
LOOKBACK_DAYS=21
TRAIL_TYPE=trail_running

# 服务端口（Railway 会自动注入，无需手动改）
PORT=8000
